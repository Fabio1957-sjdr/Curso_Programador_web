algoritmo "Crachá de Acesso"

var

    naluno: caractere
    turno: caractere

inicio

    naluno <- "Antônio de Souza"
    turno <- "Noite"

    escreval("ACESSO RESTRITO A FUNCIONÁRIOS")
    escreval("DIGITE SEU NOME:")
    //leia(naluno)
    escreval("INFORME SEU TURNO:")
    //leia(turno)
    escreval("Bem-vindo ", naluno," o seu turno é o da ", turno)
    

fimalgoritmo