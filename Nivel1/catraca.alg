algoritmo "Catraca do laboratório"

var

    idade: inteiro

inicio

    escreval("Qual é a sua idade")
    leia(idade)
    se idade >= 18 entao
        escreval("Acesso liberado ao laboratório.")
    senao
        escreval("Acesso negado. Risco de segurança. Procure seu professor.")
    fimse


fimalgoritmo