algoritmo "Desvio de fluxo de dados"

var 
aluno: caractere
professor: caractere


inicio

professor <- "Ricardo"


escreval("Bom dia, professor.")
escreval("Digite seu nome")
leia(professor)
escreval("Bem-vindo, caro estudante!")
escreval("Digite seu nome")
leia(aluno)
escreval("Bom dia professor " ,aluno, "")
escreval("Bem-vindo " ,professor, "")


fimalgoritmo