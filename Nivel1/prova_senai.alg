algoritmo "Calculando notas no Senai"

var
    nprojeto: real
    nprova: real
    resultado1: real
    resultado_final: real

inicio

escreval("Digitar a nota para o projeto")
leia(nprojeto)
escreval("Digitar a nota para a prova escrita")
leia(nprova)
escreval(resultado_final)

resultado1 <- (nprojeto*3)+(nprojeto*3)
resultado_final <- resultado1/5


fimalgoritmo