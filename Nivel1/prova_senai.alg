algoritmo "Calculando notas no Senai"

var
    nprojeto: real
    nprova: real

inicio


    escreva("Digitar a nota para o projeto: ")
    leia(nprojeto)
    escreva("Digitar a nota para a prova escrita: ")
    leia(nprova)

    escreval("Sua nota final é: " ,((nprojeto*3)+(nprova*2))/5)

   
fimalgoritmo